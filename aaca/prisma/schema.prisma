generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model User {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String?
  company_id       String            @db.Uuid
  session_id       String
  score            Int               @default(0)
  intent           String            @default("browsing")
  last_page        String?
  room_type        String?
  budget           String?
  style            String?
  service_type     String?
  created_at       DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  agent_goals      agent_goals[]
  agent_memory     agent_memory[]
  approval_logs    approval_logs[]
  bookings         bookings[]
  events           Event[]
  payments         payments[]
  requests         requests[]
  site_settings    site_settings[]
  user_preferences user_preferences?
  visitor_sessions VisitorSession[]
  companies        Company           @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "idx_users_company_id")
  @@index([company_id, intent, score], map: "idx_users_company_intent_score")
  @@map("users")
  @@schema("public")
}

model Event {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String   @db.Uuid
  user_id    String?  @db.Uuid
  type       String
  value      String?
  metadata   Json     @default("{}")
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  companies  Company  @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([company_id, created_at], map: "idx_events_company_created_at")
  @@index([company_id, type, created_at], map: "idx_events_company_type_created_at")
  @@map("events")
  @@schema("public")
}

model Company {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  domain           String             @unique
  logo             String?
  primary_color    String?
  whatsapp         String?
  created_at       DateTime           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  audit_logs       audit_logs[]
  automation_rules automation_rules[]
  bookings         bookings[]
  content          content[]
  events           Event[]
  experiments      experiments[]
  images           images[]
  media_assets     media_assets[]
  page_sections    page_sections[]
  pages            pages[]
  payments         payments[]
  requests         requests[]
  site_config      site_config[]
  users            User[]

  @@index([domain], map: "idx_companies_domain")
  @@map("companies")
  @@schema("public")
}

model RoomSection {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String    @unique
  description  String?
  image_url    String?   @default("https://images.unsplash.com/photo-1618221195710-dd6b41faeaa6?auto=format&fit=crop&q=80&w=800")
  isActive     Boolean?  @default(true) @map("is_active")
  companyId    String?   @map("company_id") @db.Uuid
  displayOrder Int       @default(autoincrement()) @map("display_order")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  nameAr       String?   @map("name_ar")
  icon         String?
  metadata     Json?

  @@map("room_sections")
  @@schema("public")
}


model VisitorSession {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId            String    @unique @map("session_id")
  leadScore            Int       @default(0) @map("lead_score")
  intent               String    @default("browsing")
  styleSwitches        Int       @default(0) @map("style_switches")
  
  userPersona          Json?     @map("user_persona")
  psychologicalProfile Json?     @map("psychological_profile")
  behavioralReport     Json?     @map("behavioral_report")
  
  lastPage             String?   @map("last_page")
  language             String    @default("ar")
  
  userId               String?   @map("user_id") @db.Uuid
  user                 User?     @relation(fields: [userId], references: [id])
  
  leadConversion       LeadConversion?
  
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([sessionId])
  @@index([intent])
  @@index([leadScore])
  @@map("visitor_sessions")
  @@schema("public")
}

model LeadConversion {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId        String          @unique @map("session_id")
  session          VisitorSession  @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  
  contactMethod    String          // e.g., "whatsapp", "form"
  contactValue     String?         // phone or email
  status           String          @default("NEW") // NEW, CONTACTED, QUALIFIED, CLOSED
  
  conversionValue  Float?          @map("conversion_value")
  notes            String?
  
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@map("lead_conversions")
  @@schema("public")
}

model ConsultantSession {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String   @unique @map("session_id")
  messages   Json     @default("[]")
  insights   Json?    @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("consultant_sessions")
  @@schema("public")
}


  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String    @db.Uuid
  user_id    String?   @db.Uuid
  request_id String?   @db.Uuid
  amount     Decimal   @db.Decimal(12, 2)
  status     String    @default("pending")
  created_at DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  companies  Company   @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  requests   requests? @relation(fields: [request_id], references: [id], onUpdate: NoAction)
  users      User?     @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([company_id, created_at], map: "idx_payments_company_created_at")
  @@schema("public")
}


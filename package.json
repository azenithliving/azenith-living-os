{
  "name": "azenith-living-os",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "aaca:start": "ts-node --transpile-only aaca/main.ts",
    "aaca:dev": "ts-node --transpile-only --watch aaca/main.ts",
    "test-curation": "ts-node --transpile-only scripts/test-curation.ts",
    "prisma:generate": "prisma generate --schema=aaca/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=aaca/prisma/schema.prisma",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run",
    "ci": "npm run lint:ci && npm run typecheck:ci && npm run test:ci",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "dependencies": {
